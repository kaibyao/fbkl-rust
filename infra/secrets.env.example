# Copy to infra/secrets.env (gitignored) and fill in. Source it before running
# tofu so the providers + apply steps see the secrets in the same shell:
#
#   source infra/secrets.env
#   tofu -chdir=infra apply
#
# Each `!`/new shell loses exports, so sourcing this each session is the reliable
# pattern (and keeps the value out of the chat transcript).

export NEON_API_KEY="napi_..."          # Neon API key (provisions neon.tf)
# export TF_VAR_app_origin="https://..." # set once Cloudflare Pages origin known (96e.8)
