# Copy to infra/secrets.env (gitignored) and fill in. Source it before running
# tofu so the providers + apply steps see the secrets in the same shell:
#
#   source infra/secrets.env
#   tofu -chdir=infra apply
#
# Each `!`/new shell loses exports, so sourcing this each session is the reliable
# pattern (and keeps the value out of the chat transcript).

# Supabase TRANSACTION pooler → Lambda FBKL_DATABASE_URL
export TF_VAR_supabase_database_url="postgresql://postgres.[your_id]:[your_password]@aws-0-[your_aws_region].pooler.supabase.com:6543/postgres"

# Cloudflare Pages · Edit
# Used by the cloudflare provider to manage the Pages projects. (The actual site
# upload happens in CI via wrangler, not here.)
export CLOUDFLARE_API_TOKEN="..."

# not secret; Cloudflare dashboard sidebar
export TF_VAR_cloudflare_account_id="..."
