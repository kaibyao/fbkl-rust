# Copy to infra/secrets.env (gitignored) and fill in. Source it before running
# tofu so the providers + apply steps see the secrets in the same shell:
#
#   source infra/secrets.env
#   tofu -chdir=infra apply
#
# Each `!`/new shell loses exports, so sourcing this each session is the reliable
# pattern (and keeps the value out of the chat transcript).

export TF_VAR_supabase_database_url="postgresql://postgres.[your_id]:[your_password]@aws-0-[your_aws_region].pooler.supabase.com:6543/postgres"  # Supabase TRANSACTION pooler → Lambda FBKL_DATABASE_URL
export CLOUDFLARE_API_TOKEN="..."               # Account · Cloudflare Pages · Edit
export TF_VAR_cloudflare_account_id="..."       # not secret; Cloudflare dashboard sidebar
